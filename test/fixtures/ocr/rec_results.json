[
  {
    "text": "1",
    "score": 0.7511
  },
  {
    "text": "\u7b2c\u4e00\u7b2c\u5546\u54c1\u548c\u8d27\u5e01",
    "score": 0.92222
  },
  {
    "text": "\u53f2\u7684\u4e8b\u60c5\u3002(3)\u4e3a\u6709\u7528\u7269\u7684\u91cf\u627e\u5230\u793e\u4f1a\u5c3a\u5ea6\uff0c\u4e5f\u662f\u8fd9\u6837\u3002\u5546\u54c1\u7684\u8fd9\u4e9b",
    "score": 0.96301
  },
  {
    "text": "\u5c3a\u5ea6\u4e4b\u6240\u4ee5\u4e0d\u540c\uff0c\u90e8\u5206\u662f\u7531\u4e8e\u88ab\u8ba1\u91cf\u7684\u7269\u7684\u6027\u8d28\u4e0d\u540c\uff0c\u90e8\u5206\u662f\u7531",
    "score": 0.99857
  },
  {
    "text": "\u4e8e\u7ea6\u5b9a\u4fd7\u6210\u3002",
    "score": 0.92626
  },
  {
    "text": "14(I",
    "score": 0.61474
  },
  {
    "text": "\u7269\u7684\u6709\u7528\u6027\u4f7f\u7269\u6210\u4e3a\u4f7f\u7528\u4ef7\u503c\u30024)\u4f46\u8fd9\u79cd\u6709\u7528\u6027\u4e0d\u662f\u98d8\u5ffd\u4e0d",
    "score": 0.97444
  },
  {
    "text": "\u5b9a\u7684\u3002\u5b83\u51b3\u5b9a\u4e8e\u5546\u54c1\u4f53\u7684\u5c5e\u6027\uff0c\u79bb\u5f00\u4e86\u5546\u54c1\u4f53\u5c31\u4e0d\u5b58\u5728\u3002\u56e0\u6b64\uff0c",
    "score": 0.99465
  },
  {
    "text": "\u5546\u54c1\u4f53\u672c\u8eab\uff0c\u4f8b\u5982\u94c1\u3001\u5c0f\u9ea6\u3001\u91d1\u94a2\u77f3\u7b49\u7b49\uff0c\u5c31\u662f\u4f7f\u7528\u4ef7\u503c\u3002\u8d4b\u4e88",
    "score": 0.98827
  },
  {
    "text": "\u5546\u54c1\u4f53\u4ee5\u8fd9\u79cd\u6027\u8d28\u7684\uff0c\u4e0d\u662f\u4eba\u4e3a\u4e86\u53d6\u5f97\u5b83\u7684\u6709\u7528\u6027\u8d28\u6240\u8017\u8d39\u7684\u52b3",
    "score": 0.99642
  },
  {
    "text": "\u52a8\u7684\u591a\u5c11\u3002\u5728\u8c08\u5230\u4f7f\u7528\u4ef7\u503c\u65f6\uff0c\u603b\u662f\u6307\u4e00\u5b9a\u7684\u91cf\u800c\u8a00\uff0c\u5982\u4e00\u6253",
    "score": 0.99368
  },
  {
    "text": "\u8868\uff0c\u4e00\u7c73\u5e03\uff0c\u4e00\u5428\u94c1\u7b49\u7b49\u3002\u5546\u54c1\u7684\u4f7f\u7528\u4ef7\u503c\u4e3a\u5546\u54c1\u5b66\u548c\u5546\u4e1a\u6210\u89c4",
    "score": 0.99806
  },
  {
    "text": "\u8fd9\u79cd\u4e13\u95e8\u7684\u77e5\u8bc6\u63d0\u4f9b\u6750\u6599\u3002\uff085\uff09\u4f7f\u7528\u4ef7\u503c\u53ea\u662f\u5728\u4f7f\u7528\u6216\u6d88\u8d39\u4e2d\u5f97\u5230",
    "score": 0.96537
  },
  {
    "text": "\u5b9e\u73b0\u3002\u4e0d\u8bba\u8d22\u5bcc\u7684\u793e\u4f1a\u5f62\u5f0f\u5982\u4f55\uff0c\u4f7f\u7528\u4ef7\u503c\u6784\u6210\u8d22\u5bcc\u7684\u7269\u8d28\u3002\u5728",
    "score": 0.99242
  },
  {
    "text": "\u6211\u4eec\u6240\u8981\u8003\u5bdf\u7684\u793e\u4f1a\u5f62\u5f0f\u4e2d\uff0c\u4f7f\u7528\u4ef7\u503c\u540c\u65f6\u53c8\u662f\u4ea4\u6362\u4ef7\u503c\u7684\u7269\u8d28",
    "score": 0.9972
  },
  {
    "text": "\u627f\u62c5\u8005\u3002",
    "score": 0.98776
  },
  {
    "text": "\u4ea4\u6362\u4ef7\u503c\u9996\u5148\u8868\u73b0\u4e3a\u91cf\u7684\u5173\u7cfb\uff0c\u8868\u73b0\u4e3a\u4e0d\u540c\u79cd\u4f7f\u7528\u4ef7\u503c\u5f7c\u6b64",
    "score": 0.99835
  },
  {
    "text": "\u76f8\u4ea4\u6362\u7684\u6bd4\u4f8b(6)\uff0c\u5373\u968f\u7740\u65f6\u95f4\u548c\u5730\u70b9\u7684\u4e0d\u540c\u800c\u4e0d\u65ad\u6539\u53d8\u7684\u5173\u7cfb\u3002",
    "score": 0.95438
  },
  {
    "text": "\u56e0\u6b64\uff0c\u4ea4\u6362\u4ef7\u503c\u597d\u8c61\u662f\u4e00\u79cd\u4efb\u610f\u7684\uff0c\u7eaf\u7cb9\u76f8\u5bf9\u7684\u4e1c\u897f\uff1b\u5546\u54c1\u56fa\u6709\u7684\u3001",
    "score": 0.94778
  },
  {
    "text": "(3\uff09 \u201c\u7269\u90fd\u6709\u5185\u5728\u7684\u957f\u5904\uff08\u8fd9\u662f\u5df4\u5c14\u672c\u7528\u6765\u8868\u793a\u4f7f\u7528\u4ef7\u503c\u7684\u4e13\u95e8\u7528\u8bed)\uff0c\u8fd9\u79cd\u957f",
    "score": 0.93085
  },
  {
    "text": "\u5904\u5728\u4efb\u4f55\u5730\u65b9\u90fd\u5177\u6709\u540c\u6837\u7684\u6027\u8d28\uff0c\u5982\u78c1\u77f3\u5438\u94c1\u7684\u957f\u5904\u5c31\u662f\u5982\u6b64\u3002\u201d\uff08\u5c3c\u53e4\u62c9\u00b7\u5df4\u5c14\u672c",
    "score": 0.9715
  },
  {
    "text": "\u300a\u65b0\u5e01\u8f7b\u94f8\u8bba\u3002\u7b54\u6d1b\u514b\u5148\u751f\u5173\u4e8e\u63d0\u9ad8\u8d27\u5e01\u4ef7\u503c\u7684\u610f\u89c11696\u5e74\u4f26\u6566\u7248\u7b2c16\u9875\uff09\u78c1\u77f3\u5438",
    "score": 0.97157
  },
  {
    "text": "\u94c1\u7684\u5c5e\u6027\u53ea\u662f\u5728\u901a\u8fc7\u5b83\u53d1\u73b0\u4e86\u78c1\u6781\u6027\u4ee5\u540e\u624d\u6210\u4e3a\u6709\u7528\u7684\u3002",
    "score": 0.99104
  },
  {
    "text": "(4) \u201c\u7269\u7684\u81ea\u7136\u4ef7\u503c\u4ea7\u751f\u4e8e\u5b83\u80fd\u6ee1\u8db3\u9700\u8981\uff0c\u6216\u8005\u7ed9\u4eba\u7c7b\u751f\u6d3b\u5e26\u6765\u65b9\u4fbf\u3002\u201d\u7ea6\u7ff0\u00b7",
    "score": 0.95993
  },
  {
    "text": "\u6d1b\u514b\uff1a\u300a\u8bba\u964d\u4f4e\u5229\u606f\u7684\u540e\u679c\u300b(1691\u5e74)\u3002\u5728\u5341\u4e03\u4e16\u7eaa\uff0c\u6211\u4eec\u8fd8\u5e38\u5e38\u770b\u5230\u82f1\u56fd\u8457\u4f5c\u5bb6\u7528",
    "score": 0.95713
  },
  {
    "text": "worth\u8868\u793a\u4f7f\u7528\u4ef7\u503c\uff0c\u7528valu\u8868\u793a\u4ea4\u6362\u4ef7\u503c\uff1b\u8fd9\u5b8c\u5168\u7b26\u5408\u82f1\u8bed\u7684\u7cbe\u795e\uff0c\u82f1\u8bed\u559c\u6b22",
    "score": 0.96955
  },
  {
    "text": "\u7528\u65e5\u8033\u66fc\u8bed\u6e90\u7684\u8bcd\u8868\u793a\u76f4\u63a5\u7684\u4e1c\u897f\uff0c\u7528\u7f57\u9a6c\u8bed\u6e90\u7684\u8bcd\u8868\u793a\u88ab\u53cd\u5c04\u7684\u4e1c\u897f\u3002",
    "score": 0.98919
  },
  {
    "text": "\uff085\uff09 \u5728\u8d44\u4ea7\u9636\u7ea7\u793e\u4f1a\u4e2d\u201c\u4efb\u4f55\u4eba\u90fd\u4e0d\u80fd\u63a8\u6258\u4e0d\u77e5\u9053\u6cd5\u5f8b\u201d\u3002\u2014\u2014\u6309\u7167\u7ecf\u6d4e\u6cd5\u7684",
    "score": 0.91034
  },
  {
    "text": "\u5047\u5b9a\uff0c\u6bcf\u4e2a\u4e70\u8005\u90fd\u5177\u6709\u767e\u79d1\u5168\u4e66\u822c\u7684\u5546\u54c1\u77e5\u8bc6\u3002",
    "score": 0.9978
  },
  {
    "text": "(6) \u201c\u4ef7\u503c\u5c31\u662f\u4e00\u7269\u548c\u53e6\u4e00\u7269\uff0c\u4e00\u5b9a\u91cf\u7684\u8fd9\u79cd\u4ea7\u54c1\u548c\u4e00\u5b9a\u91cf\u7684\u522b\u79cd\u4ea7\u54c1\u4e4b\u95f4\u7684",
    "score": 0.96459
  },
  {
    "text": "\u4ea4\u6362\u5173\u7cfb\u3002\u201d(\u5217\u7279\u9686\u300a\u8bba\u793e\u4f1a\u5229\u76ca\u300b\uff0c\u5fb7\u5c14\u7f16\u300a\u91cd\u519c\u5b66\u6d3e\u300b1846\u5e74\u5df4\u9ece\u7248\u7b2c889\u9875\uff09",
    "score": 0.90084
  }
]